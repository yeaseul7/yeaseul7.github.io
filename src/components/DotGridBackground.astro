<canvas class="dot-grid-background" data-dot-grid aria-hidden="true"></canvas>

<script>
  (() => {
    const canvas = document.querySelector('[data-dot-grid]');
    if (!(canvas instanceof HTMLCanvasElement) || canvas.dataset.ready) return;

    canvas.dataset.ready = 'true';
    const context = canvas.getContext('2d');
    if (!context) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const pointer = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
    const target = { ...pointer };
    let width = 0;
    let height = 0;
    let frame = 0;
    let visible = true;

    const resize = () => {
      const ratio = Math.min(window.devicePixelRatio || 1, 2);
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = Math.round(width * ratio);
      canvas.height = Math.round(height * ratio);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context.setTransform(ratio, 0, 0, ratio, 0, 0);
      pointer.x = target.x = width / 2;
      pointer.y = target.y = height / 2;
    };

    const themeColor = () => {
      const dark = document.documentElement.dataset.theme === 'dark';
      return dark ? [126, 134, 143] : [100, 116, 139];
    };

    const draw = (time = 0) => {
      context.clearRect(0, 0, width, height);

      if (!reduceMotion.matches) {
        pointer.x += (target.x - pointer.x) * 0.055;
        pointer.y += (target.y - pointer.y) * 0.055;
      }

      const spacing = 16;
      const spotlightRadius = Math.min(150, Math.max(100, width * 0.1));
      const [red, green, blue] = themeColor();
      const columns = Math.ceil(width / spacing) + 4;
      const rows = Math.ceil(height / spacing) + 4;

      for (let row = -2; row < rows; row += 1) {
        for (let column = -2; column < columns; column += 1) {
          const baseX = column * spacing;
          const baseY = row * spacing;
          const dx = baseX - pointer.x;
          const dy = baseY - pointer.y;
          const distance = Math.hypot(dx, dy);
          const influence = Math.max(0, 1 - distance / spotlightRadius);
          const brightness = influence * influence * (3 - 2 * influence);
          const brightRed = red + (255 - red) * brightness * 0.92;
          const brightGreen = green + (255 - green) * brightness * 0.92;
          const brightBlue = blue + (255 - blue) * brightness * 0.92;
          const alpha = 0.42 + brightness * 0.58;

          context.beginPath();
          context.arc(baseX, baseY, 0.7, 0, Math.PI * 2);
          context.fillStyle = `rgba(${brightRed}, ${brightGreen}, ${brightBlue}, ${alpha})`;
          context.fill();
        }
      }

      if (visible && !reduceMotion.matches) frame = requestAnimationFrame(draw);
    };

    const restart = () => {
      cancelAnimationFrame(frame);
      draw(performance.now());
    };

    // Render first so optional browser APIs cannot prevent initialization.
    resize();
    draw();

    window.addEventListener('resize', () => {
      resize();
      if (reduceMotion.matches) restart();
    }, { passive: true });

    const movePointer = (event) => {
      target.x = event.clientX;
      target.y = event.clientY;
    };

    if ('PointerEvent' in window) {
      window.addEventListener('pointermove', movePointer, { passive: true });
    } else {
      window.addEventListener('mousemove', movePointer, { passive: true });
    }

    document.addEventListener('pointerleave', () => {
      target.x = width / 2;
      target.y = height / 2;
    });

    document.addEventListener('visibilitychange', () => {
      visible = !document.hidden;
      if (visible) restart();
      else cancelAnimationFrame(frame);
    });

    if (typeof reduceMotion.addEventListener === 'function') {
      reduceMotion.addEventListener('change', restart);
    } else if (typeof reduceMotion.addListener === 'function') {
      reduceMotion.addListener(restart);
    }

    if ('MutationObserver' in window) {
      new MutationObserver(restart).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme'],
      });
    }
  })();
</script>
