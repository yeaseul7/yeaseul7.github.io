---
interface Props {
  url: string;
  label: string;
}

const { url, label } = Astro.props;
---

<a class="download-link" href={url} download>
  <svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
    <path d="M5 20h14v-2H5v2ZM13 4h-2v8.2L7.4 8.6 6 10l6 6 6-6-1.4-1.4-3.6 3.6V4Z"></path>
  </svg>
  <span>{label}</span>
</a>

<style>
  .download-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 0 0 22px;
    padding: 9px 14px;
    border-radius: 8px;
    background-color: #2563eb;
    color: #fff;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 8px 20px rgba(37, 99, 235, 0.22);
    transition:
      background-color 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .download-link svg {
    flex: 0 0 auto;
    fill: currentColor;
  }

  .download-link:hover {
    background-color: #1d4ed8;
    color: #fff;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(37, 99, 235, 0.28);
  }

  .download-link:focus-visible {
    outline: 2px solid #93c5fd;
    outline-offset: 3px;
  }
</style>
